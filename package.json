{
  "devDependencies": {
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx}": [
      "npm --prefix frontend run lint",
      "prettier --write --project frontend"
    ],
    "backend/src/**/*.ts": [
      "npm --prefix backend run lint",
      "prettier --write --project backend"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
